# Production build values. Next.js loads this automatically for `next build` / `next start`,
# taking precedence over .env's NEXT_PUBLIC_* values so a production build always
# gets the real backend/site URLs regardless of what's active in .env for local dev.

NEXT_PUBLIC_API_BASE_URL=https://qadayaapi.naqreo.com/api
NEXT_PUBLIC_BACKEND_URL=https://qadayaapi.naqreo.com/api
NEXT_PUBLIC_BACKEND_HOST=qadayaapi.naqreo.com
NEXT_PUBLIC_SITE_URL=https://qadaya.naqreo.com
NEXT_PUBLIC_APP_NAME=LawyerSys Client
NEXT_PUBLIC_APP_ENV=production
