  <data name="RegistrationNotificationBody" xml:space="preserve">
    <value><![CDATA[<div style="font-family:Arial,sans-serif;color:#1f2937;line-height:1.7">
<h2 style="margin-bottom:8px;color:#0f172a;">New registration pending activation</h2>
<p style="margin-top:0;">A new tenant administrator has registered and is waiting for SuperAdmin activation.</p>
<table style="border-collapse:collapse;width:100%;max-width:720px;">
  <tr><td style="padding:8px;border:1px solid #e5e7eb;"><strong>Full name</strong></td><td style="padding:8px;border:1px solid #e5e7eb;">{FullName}</td></tr>
  <tr><td style="padding:8px;border:1px solid #e5e7eb;"><strong>Username</strong></td><td style="padding:8px;border:1px solid #e5e7eb;">{UserName}</td></tr>
  <tr><td style="padding:8px;border:1px solid #e5e7eb;"><strong>Email</strong></td><td style="padding:8px;border:1px solid #e5e7eb;">{Email}</td></tr>
  <tr><td style="padding:8px;border:1px solid #e5e7eb;"><strong>Office name</strong></td><td style="padding:8px;border:1px solid #e5e7eb;">{OfficeName}</td></tr>
  <tr><td style="padding:8px;border:1px solid #e5e7eb;"><strong>Office phone</strong></td><td style="padding:8px;border:1px solid #e5e7eb;">{OfficePhone}</td></tr>
  <tr><td style="padding:8px;border:1px solid #e5e7eb;"><strong>Country</strong></td><td style="padding:8px;border:1px solid #e5e7eb;">{Country}</td></tr>
  <tr><td style="padding:8px;border:1px solid #e5e7eb;"><strong>Tenant ID</strong></td><td style="padding:8px;border:1px solid #e5e7eb;">{TenantId}</td></tr>
  <tr><td style="padding:8px;border:1px solid #e5e7eb;"><strong>Registered at (UTC)</strong></td><td style="padding:8px;border:1px solid #e5e7eb;">{RegisteredAtUtc}</td></tr>
</table>
<p style="margin-top:16px;">Review the account and activate it from the administration screen when ready.</p>
</div>]]></value>
